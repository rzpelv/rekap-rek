# =============================================================================
#   Rekapin — Environment Variables (contoh)
# =============================================================================
#   Copy file ini jadi `.env` dan isi nilai yang sesuai:
#       cp .env.example .env
#
#   Lalu jalankan app dengan:
#       export $(cat .env | xargs) && python app.py        # Linux/Mac
#       py -m dotenv run python app.py                     # Windows (butuh: pip install python-dotenv)
#
#   ATAU set langsung di terminal:
#       export GEMINI_API_KEY="..."
#       python app.py
# =============================================================================

# ── AI Provider ──────────────────────────────────────────────────────────────
# auto   = pakai Gemini kalau API key ada, fallback ke Ollama (default)
# gemini = paksa pakai Gemini cloud
# ollama = paksa pakai Ollama lokal
REKAPIN_AI_PROVIDER=auto


# ── Google Gemini (Cloud, GRATIS) ────────────────────────────────────────────
# Daftar gratis di: https://aistudio.google.com/apikey
# Free tier: 1.500 request/hari untuk gemini-2.0-flash
# Cocok untuk: tidak install apapun, akurasi tinggi, hasil cepat
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash


# ── Ollama (Lokal, GRATIS, Private) ──────────────────────────────────────────
# Install dari https://ollama.com lalu pull model:
#     ollama pull qwen3.5:2b   (terbaru 2026, ringan & akurat)
# Cocok untuk: privacy, offline, tidak ada limit request
REKAPIN_AI_MODEL=qwen3.5:2b
REKAPIN_AI_URL=http://localhost:11434
REKAPIN_AI_TIMEOUT=120


# ── Server ───────────────────────────────────────────────────────────────────
PORT=8080
